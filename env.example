# ============================================
# Homeschoolars — environment configuration
# ============================================
# Copy to .env.local and set real values:
#   cp env.example .env.local
# Restart the dev server after changes.
# Never commit .env.local.

# ============================================
# Site URL (required for emails, Stripe return, PDFs, webhooks)
# ============================================
# Public site origin, no trailing slash.
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (use https in live deploys):
# NEXT_PUBLIC_APP_URL=https://homeschoolars.com

# ============================================
# Branding (UI, lesson player, PDFs — all NEXT_PUBLIC_* are exposed to the browser)
# ============================================
NEXT_PUBLIC_APP_NAME=Homeschoolars
NEXT_PUBLIC_APP_TAGLINE=Raising Thinkers, Not Just Students
# Path under /public or absolute https URL (for external CDN logos)
NEXT_PUBLIC_APP_LOGO_URL=/homeschoolars-logo-v2.png
# Optional: browser tab / SEO description (defaults to a generic line if unset)
# NEXT_PUBLIC_APP_DESCRIPTION=Personalized homeschooling for ages 4–13.

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/homeschoolar
# Production Docker/Cloud Run: the image runs standalone `node server.js` and does NOT run migrations on boot
# (so the process can listen on PORT immediately). Run before each deploy, e.g.:
#   DATABASE_URL="..." npx prisma migrate deploy
# or a Cloud Build / GitHub Actions step with the same DATABASE_URL as Cloud Run.

# ============================================
# Auth.js / NextAuth
# ============================================
# openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
# Optional alias; Auth.js v5 may read AUTH_SECRET only
# NEXTAUTH_SECRET=your-auth-secret-here
# Server-side URL for callbacks and magic links (should match your public URL in production)
AUTH_URL=http://localhost:3000
# Production:
# AUTH_URL=https://homeschoolars.com
# Cloud Run: ensure DATABASE_URL and AUTH_SECRET are set on the service; the app sets trustHost in auth.ts for proxy headers.
# Optional: separate secret for student session cookies (else AUTH_SECRET / NEXTAUTH_SECRET)
# STUDENT_SESSION_SECRET=

# ============================================
# OpenAI (AI worksheets, quizzes, stories, grading)
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
AI_DAILY_LIMIT=50

# ============================================
# Stripe
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ============================================
# Payoneer / JazzCash / EasyPaisa
# ============================================
PAYONEER_API_BASE=https://sandbox.payoneer.com
PAYONEER_API_KEY=your-payoneer-api-key
PAYONEER_WEBHOOK_SECRET=your-payoneer-webhook-secret

JAZZCASH_API_BASE=https://sandbox.jazzcash.com.pk
JAZZCASH_MERCHANT_ID=your-jazzcash-merchant-id
JAZZCASH_PASSWORD=your-jazzcash-password
JAZZCASH_WEBHOOK_SECRET=your-jazzcash-webhook-secret

EASYPAISA_API_BASE=https://sandbox.easypaisa.com.pk
EASYPAISA_MERCHANT_ID=your-easypaisa-merchant-id
EASYPAISA_API_KEY=your-easypaisa-api-key
EASYPAISA_WEBHOOK_SECRET=your-easypaisa-webhook-secret

# ============================================
# PKR pricing (optional)
# ============================================
PKR_PER_USD=280

# ============================================
# Backend / Python API (rewrites /api/py/*)
# ============================================
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# ============================================
# CORS (if you run a separate backend)
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=re_your-resend-api-key-here
VERIFICATION_EMAIL_FROM=HomeSchoolar <noreply@your-domain.com>
PASSWORD_RESET_EMAIL_FROM=HomeSchoolar <noreply@your-domain.com>

# ============================================
# Subscriptions & trials
# ============================================
TRIAL_DAYS=14
MAX_AI_CALLS_TRIAL=25

# ============================================
# Admin & ops (optional)
# ============================================
# Protects POST /api/admin/make-admin
# ADMIN_SETUP_SECRET=
# Protects cron routes e.g. news refresh
# CRON_SECRET=
# Orphan document uploads
# ORPHAN_DOC_STORAGE_DIR=
# Comma-separated MIME types, e.g. application/pdf,image/jpeg
# ORPHAN_DOC_ALLOWED_TYPES=

# ============================================
# Analytics
# ============================================
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false

# ============================================
# Node (usually set by the host; do not set locally unless needed)
# ============================================
# NODE_ENV=development
