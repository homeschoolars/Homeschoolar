generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                  @id @default(uuid())
  email               String                  @unique
  emailVerified       DateTime?               @map("email_verified")
  name                String?                 @map("full_name")
  role                UserRole                @default(parent)
  image               String?                 @map("avatar_url")
  passwordHash        String?                 @map("password_hash")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @default(now()) @map("updated_at")
  adminRole           AdminRole?              @map("admin_role")
  accounts            Account[]
  adminAuditLogs      AdminAuditLog[]
  analytics           AnalyticsEvent[]
  blogPosts           BlogPost[]
  preferences         NotificationPreference?
  notifications       Notification[]
  orphanReviews       OrphanVerification[]    @relation("OrphanReviewedBy")
  orphanSubmissions   OrphanVerification[]    @relation("OrphanSubmittedBy")
  parentProfile       Parent?
  paymentTransactions PaymentTransaction[]
  payments            Payment[]
  verifiedPayments    Payment[]               @relation("PaymentVerifier")
  sessions            Session[]
  children            Child[]
  subscriptions       Subscription?
  videoLectures       VideoLecture[]          @relation("VideoLectureCreator")
  assignedWorksheets  WorksheetAssignment[]   @relation("WorksheetAssigner")
  createdWorksheets   Worksheet[]             @relation("WorksheetCreator")

  @@map("profiles")
}

model Parent {
  id           String             @id @default(uuid())
  userId       String             @unique @map("user_id")
  fullName     String             @map("full_name")
  relationship ParentRelationship
  email        String
  phone        String?
  country      String
  timezone     String
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @default(now()) @map("updated_at")
  trialUsedAt  DateTime?          @map("trial_used_at")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parents")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Child {
  id                  String                  @id @default(uuid())
  parentId            String                  @map("parent_id")
  name                String
  ageGroup            AgeGroup                @map("age_group")
  avatarUrl           String?                 @map("avatar_url")
  loginCode           String                  @unique @map("login_code")
  currentLevel        LearningLevel           @default(beginner) @map("current_level")
  learningStyle       String?                 @map("learning_style")
  interests           String[]
  assessmentCompleted Boolean                 @default(false) @map("assessment_completed")
  lastQuizAt          DateTime?               @map("last_quiz_at")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @default(now()) @map("updated_at")
  isOrphan            Boolean                 @default(false) @map("is_orphan")
  orphanStatus        OrphanStatus            @default(rejected) @map("orphan_status")
  recommendations     AIRecommendation[]
  analytics           AnalyticsEvent[]
  assessments         Assessment[]
  behavioralMemory    BehavioralMemory?
  interestsV2         ChildInterest[]
  profile             ChildProfile?
  curriculumPaths     CurriculumPath[]
  initialAssessments  InitialAssessment[]
  learningMemory      LearningMemory[]
  preferences         LearningPreference?
  roadmaps            LearningRoadmap[]
  orphanVerifications OrphanVerification[]
  progress            Progress[]
  learningProfile     StudentLearningProfile?
  parent              User                    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subscriptions       Subscription[]
  quizzes             SurpriseQuiz[]
  assignments         WorksheetAssignment[]
  submissions         WorksheetSubmission[]
  lessonProgress      StudentLessonProgress[]
  generatedContents   CurriculumGeneratedContent[]
  subjectExams        SubjectExam[]

  @@index([parentId])
  @@index([ageGroup])
  @@map("students")
}

model ChildProfile {
  id             String   @id @default(uuid())
  childId        String   @unique @map("child_id")
  dateOfBirth    DateTime @map("date_of_birth")
  ageYears       Int      @map("age_years")
  gender         Gender?
  religion       Religion
  educationLevel String?  @map("education_level")
  strengths      String?
  challenges     String?
  aiSummary      Json?    @map("ai_summary")
  aiReasoning    Json?    @map("ai_reasoning")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")
  child          Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([ageYears])
  @@index([religion])
  @@map("child_profiles")
}

model LearningPreference {
  id                 String          @id @default(uuid())
  childId            String          @unique @map("child_id")
  learningStyles     LearningStyle[] @map("learning_styles")
  attentionSpan      AttentionSpan   @map("attention_span")
  screenTolerance    ScreenTolerance @map("screen_tolerance")
  needsEncouragement Boolean         @default(false) @map("needs_encouragement")
  learnsBetterWith   LearningMode[]  @map("learns_better_with")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @default(now()) @map("updated_at")
  child              Child           @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("learning_preferences")
}

model ChildInterest {
  id        String         @id @default(uuid())
  childId   String         @map("child_id")
  label     String
  source    InterestSource @default(preset)
  createdAt DateTime       @default(now()) @map("created_at")
  child     Child          @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([label])
  @@map("child_interests")
}

model InitialAssessment {
  id                String   @id @default(uuid())
  childId           String   @map("child_id")
  subjectId         String?  @map("subject_id")
  rawResponses      Json?    @map("raw_responses")
  subjectConfidence Json?    @map("subject_confidence")
  evaluatedSkills   Json?    @map("evaluated_skills")
  aiReasoning       Json?    @map("ai_reasoning")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  child             Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  subject           Subject? @relation(fields: [subjectId], references: [id])

  @@index([childId])
  @@map("initial_assessments")
}

model Subject {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  icon               String?
  color              String?
  displayOrder       Int                 @default(0) @map("display_order")
  createdAt          DateTime            @default(now()) @map("created_at")
  assessments        Assessment[]
  curriculumPaths    CurriculumPath[]
  initialAssessments InitialAssessment[]
  learningMemory     LearningMemory[]
  lessonContents     LessonContent[]
  lessonQuizzes      LessonQuiz[]
  curriculumSubjects CurriculumSubject[]
  progress           Progress[]
  quizzes            SurpriseQuiz[]
  worksheets         Worksheet[]
  subjectExams       SubjectExam[]

  @@map("subjects")
}

model CurriculumAgeGroup {
  id        String              @id @default(uuid())
  name      String              @unique
  ageMin    Int                 @default(4) @map("age_min")
  ageMax    Int                 @default(5) @map("age_max")
  orderIndex Int                @default(0) @map("order_index")
  stageName String              @default("Foundation") @map("stage_name")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  subjects  CurriculumSubject[]

  @@map("curriculum_age_groups")
}

model CurriculumSubject {
  id          String              @id @default(uuid())
  name        String
  slug        String
  category    CurriculumSubjectCategory @default(CORE)
  ageGroupId  String              @map("age_group_id")
  baseSubjectId String?           @map("base_subject_id")
  orderIndex  Int                 @default(0) @map("order_index")
  displayOrder Int                @default(0) @map("display_order")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  ageGroup    CurriculumAgeGroup  @relation(fields: [ageGroupId], references: [id], onDelete: Cascade)
  baseSubject Subject?            @relation(fields: [baseSubjectId], references: [id], onDelete: SetNull)
  units       CurriculumUnit[]

  @@unique([ageGroupId, slug])
  @@index([baseSubjectId])
  @@map("curriculum_subjects")
}

model CurriculumUnit {
  id          String             @id @default(uuid())
  title       String
  slug        String
  subjectId   String             @map("subject_id")
  orderIndex  Int                @default(0) @map("order_index")
  displayOrder Int               @default(0) @map("display_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  subject     CurriculumSubject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  lessons     CurriculumLesson[]
  generatedContents CurriculumGeneratedContent[]

  @@unique([subjectId, slug])
  @@map("curriculum_units")
}

model CurriculumLesson {
  id          String                     @id @default(uuid())
  title       String
  slug        String
  unitId      String                     @map("unit_id")
  difficultyLevel String                 @default("foundation") @map("difficulty_level")
  orderIndex  Int                        @default(0) @map("order_index")
  displayOrder Int                       @default(0) @map("display_order")
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")
  unit        CurriculumUnit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  content     CurriculumContent?
  aiPrompts   CurriculumAIPrompt[]
  generations CurriculumGeneratedContent[]
  studentProgress StudentLessonProgress[]

  @@unique([unitId, slug])
  @@map("curriculum_lessons")
}

model CurriculumContent {
  id                   String           @id @default(uuid())
  lessonId             String           @unique @map("lesson_id")
  storyText            String           @map("story_text")
  activityInstructions String           @map("activity_instructions")
  quizConcept          String           @map("quiz_concept")
  worksheetExample     String           @map("worksheet_example")
  parentTip            String           @map("parent_tip")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  lesson               CurriculumLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("curriculum_contents")
}

model CurriculumAIPrompt {
  id             String               @id @default(uuid())
  lessonId       String               @map("lesson_id")
  type           CurriculumPromptType
  promptTemplate String               @map("prompt_template")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  lesson         CurriculumLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, type])
  @@map("curriculum_ai_prompts")
}

model CurriculumGeneratedContent {
  id             String               @id @default(uuid())
  lessonId       String               @map("lesson_id")
  unitId         String?              @map("unit_id")
  studentId      String?              @map("student_id")
  type           CurriculumPromptType
  sessionKey     String               @default("global") @map("session_key")
  visibility     GeneratedContentVisibility @default(private)
  generatedBy    GeneratedContentSource @default(system) @map("generated_by")
  content        String
  contentJson    Json?                @map("content_json")
  promptSnapshot String               @map("prompt_snapshot")
  model          String               @default("gpt-4o-mini")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  lesson         CurriculumLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  unit           CurriculumUnit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  student        Child?               @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([lessonId, type])
  @@unique([lessonId, type, sessionKey])
  @@map("curriculum_generated_contents")
}

model SubjectExam {
  id             String   @id @default(cuid())
  studentId      String   @map("student_id")
  subjectId      String   @map("subject_id")
  examJson       Json     @map("exam_json")
  score          Decimal? @db.Decimal(5, 2)
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  student        Child    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([studentId, subjectId])
  @@map("subject_exams")
}

model StudentLessonProgress {
  id             String           @id @default(cuid())
  studentId      String           @map("student_id")
  lessonId       String           @map("lesson_id")
  status         LessonStatus     @default(locked)
  quizPassed     Boolean          @default(false) @map("quiz_passed")
  completedAt    DateTime?        @map("completed_at")
  lastAccessedAt DateTime?        @map("last_accessed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  student        Child            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson         CurriculumLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId, status])
  @@map("student_lesson_progress")
}

model Worksheet {
  id            String                @id @default(uuid())
  title         String
  description   String?
  subjectId     String                @map("subject_id")
  ageGroup      AgeGroup              @map("age_group")
  difficulty    Difficulty            @default(medium)
  questions     Json                  @default("[]")
  answerKey     Json?                 @map("answer_key")
  explanations  Json?                 @map("explanations")
  aiPrompt      String?               @map("ai_prompt")
  isAiGenerated Boolean               @default(false) @map("is_ai_generated")
  isApproved    Boolean               @default(false) @map("is_approved")
  createdBy     String?               @map("created_by")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @default(now()) @map("updated_at")
  analytics     AnalyticsEvent[]
  assignments   WorksheetAssignment[]
  creator       User?                 @relation("WorksheetCreator", fields: [createdBy], references: [id])
  subject       Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("worksheets")
}

model WorksheetAssignment {
  id          String                @id @default(uuid())
  worksheetId String                @map("worksheet_id")
  childId     String                @map("child_id")
  assignedBy  String                @map("assigned_by")
  dueDate     DateTime?             @map("due_date")
  status      AssignmentStatus      @default(pending)
  createdAt   DateTime              @default(now()) @map("created_at")
  assigner    User                  @relation("WorksheetAssigner", fields: [assignedBy], references: [id], onDelete: Cascade)
  child       Child                 @relation(fields: [childId], references: [id], onDelete: Cascade)
  worksheet   Worksheet             @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  submissions WorksheetSubmission[]

  @@unique([worksheetId, childId])
  @@map("worksheet_assignments")
}

model WorksheetSubmission {
  id           String              @id @default(uuid())
  assignmentId String              @map("assignment_id")
  childId      String              @map("child_id")
  answers      Json                @default("[]")
  score        Decimal?            @db.Decimal(5, 2)
  maxScore     Decimal?            @map("max_score") @db.Decimal(5, 2)
  aiFeedback   String?             @map("ai_feedback")
  submittedAt  DateTime            @default(now()) @map("submitted_at")
  gradedAt     DateTime?           @map("graded_at")
  assignment   WorksheetAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  child        Child               @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("worksheet_submissions")
}

model Progress {
  id                  String    @id @default(uuid())
  childId             String    @map("child_id")
  subjectId           String    @map("subject_id")
  totalWorksheets     Int       @default(0) @map("total_worksheets")
  completedWorksheets Int       @default(0) @map("completed_worksheets")
  totalScore          Decimal   @default(0) @map("total_score") @db.Decimal(10, 2)
  averageScore        Decimal   @default(0) @map("average_score") @db.Decimal(5, 2)
  lastActivityAt      DateTime? @map("last_activity_at")
  updatedAt           DateTime  @default(now()) @map("updated_at")
  child               Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  subject             Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([childId, subjectId])
  @@map("progress")
}

model Subscription {
  id                   String                @id @default(uuid())
  userId               String                @unique @map("user_id")
  childId              String?               @map("child_id")
  plan                 SubscriptionPlanId
  status               SubscriptionStatus    @default(active)
  stripeCustomerId     String?               @map("stripe_customer_id")
  stripeSubscriptionId String?               @map("stripe_subscription_id")
  paypalSubscriptionId String?               @map("paypal_subscription_id")
  paymentProvider      String?               @default("stripe") @map("payment_provider")
  amountPaid           Int                   @default(0) @map("amount_paid")
  currency             String                @default("usd")
  gateway              PaymentGateway?       @map("gateway")
  amount               Int?                  @map("amount")
  metadata             Json?                 @default("{}")
  startDate            DateTime?             @map("start_date")
  endDate              DateTime?             @map("end_date")
  currentPeriodStart   DateTime?             @map("current_period_start")
  currentPeriodEnd     DateTime?             @map("current_period_end")
  trialEndsAt          DateTime?             @map("trial_ends_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @default(now()) @map("updated_at")
  baseMonthlyPrice     Int?                  @map("base_monthly_price")
  billingCurrency      BillingCurrency?      @map("billing_currency")
  childCount           Int                   @default(1) @map("child_count")
  couponCode           String?               @map("coupon_code")
  discountAmount       Int?                  @map("discount_amount")
  discountPercentage   Int                   @default(0) @map("discount_percentage")
  expiresAt            DateTime?             @map("expires_at")
  finalAmount          Int?                  @map("final_amount")
  planType             SubscriptionPlanType? @map("plan_type")
  pricingMetadata      Json?                 @default("{}") @map("pricing_metadata")
  startedAt            DateTime?             @map("started_at")
  type                 SubscriptionType      @default(paid)
  isFree               Boolean               @default(false) @map("is_free")
  transactions         PaymentTransaction[]
  payments             Payment[]
  child                Child?                @relation(fields: [childId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([childCount])
  @@index([planType])
  @@map("subscriptions")
}

model PaymentTransaction {
  id             String         @id @default(uuid())
  userId         String?        @map("user_id")
  subscriptionId String?        @map("subscription_id")
  gateway        PaymentGateway @map("gateway")
  amount         Int
  currency       String
  status         PaymentStatus  @default(pending)
  externalId     String?        @map("external_id")
  referenceId    String?        @map("reference_id")
  metadata       Json?          @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @map("updated_at")
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])

  @@unique([gateway, externalId])
  @@unique([gateway, referenceId])
  @@map("payment_transactions")
}

model Payment {
  id                   String           @id @default(uuid())
  userId               String?          @map("user_id")
  subscriptionId       String?          @map("subscription_id")
  provider             String           @default("stripe")
  paymentMethod        String?          @map("payment_method")
  providerPaymentId    String?          @map("provider_payment_id")
  amount               Int
  currency             String           @default("usd")
  status               PaymentStatus    @default(pending)
  description          String?
  metadata             Json?            @default("{}")
  verifiedAt           DateTime?        @map("verified_at")
  verifiedBy           String?          @map("verified_by")
  rejectionReason      String?          @map("rejection_reason")
  createdAt            DateTime         @default(now()) @map("created_at")
  paymentProvider      PaymentProvider? @map("payment_provider")
  transactionReference String?          @map("transaction_reference")
  subscription         Subscription?    @relation(fields: [subscriptionId], references: [id])
  user                 User?            @relation(fields: [userId], references: [id])
  verifier             User?            @relation("PaymentVerifier", fields: [verifiedBy], references: [id])

  @@unique([provider, providerPaymentId])
  @@map("payments")
}

model OrphanVerification {
  id                  String                   @id @default(uuid())
  childId             String                   @map("child_id")
  submittedByParentId String                   @map("submitted_by_parent_id")
  documentType        OrphanDocumentType
  documentUrl         String                   @map("document_url")
  status              OrphanVerificationStatus @default(pending)
  reviewedByAdminId   String?                  @map("reviewed_by_admin_id")
  reviewedAt          DateTime?                @map("reviewed_at")
  rejectionReason     String?                  @map("rejection_reason")
  createdAt           DateTime                 @default(now()) @map("created_at")
  child               Child                    @relation(fields: [childId], references: [id], onDelete: Cascade)
  reviewedBy          User?                    @relation("OrphanReviewedBy", fields: [reviewedByAdminId], references: [id])
  submittedBy         User                     @relation("OrphanSubmittedBy", fields: [submittedByParentId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([status])
  @@map("orphan_verifications")
}

model SubscriptionPlan {
  id               String   @id
  name             String
  description      String?
  priceMonthly     Int      @default(0) @map("price_monthly")
  priceYearly      Int      @default(0) @map("price_yearly")
  features         Json?    @default("[]")
  aiWorksheetLimit Int      @default(-1) @map("ai_worksheet_limit")
  aiQuizLimit      Int      @default(-1) @map("ai_quiz_limit")
  maxChildren      Int      @default(-1) @map("max_children")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("subscription_plans")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  title       String
  message     String
  type        NotificationType @default(info)
  isRead      Boolean          @default(false) @map("is_read")
  actionUrl   String?          @map("action_url")
  actionLabel String?          @map("action_label")
  metadata    Json?            @default("{}")
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NotificationPreference {
  id                      String   @id @default(uuid())
  userId                  String   @unique @map("user_id")
  emailQuizResults        Boolean  @default(true) @map("email_quiz_results")
  emailProgressUpdates    Boolean  @default(true) @map("email_progress_updates")
  emailAiRecommendations  Boolean  @default(true) @map("email_ai_recommendations")
  emailSubscriptionAlerts Boolean  @default(true) @map("email_subscription_alerts")
  emailWeeklySummary      Boolean  @default(true) @map("email_weekly_summary")
  inappQuizAlerts         Boolean  @default(true) @map("inapp_quiz_alerts")
  inappWorksheetCompleted Boolean  @default(true) @map("inapp_worksheet_completed")
  inappRecommendations    Boolean  @default(true) @map("inapp_recommendations")
  inappAchievements       Boolean  @default(true) @map("inapp_achievements")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @map("updated_at")
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Assessment {
  id                  String               @id @default(uuid())
  childId             String               @map("child_id")
  subjectId           String               @map("subject_id")
  questions           Json
  answers             Json?
  score               Int?
  recommendedLevel    String?              @map("recommended_level")
  completedAt         DateTime?            @map("completed_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  assessmentType      AssessmentType       @default(baseline) @map("assessment_type")
  difficultyLevel     Difficulty?          @map("difficulty_level")
  status              AssessmentStatus     @default(pending)
  conductedBy         ConductedBy?         @map("conducted_by")
  rawAnswers          Json?                @map("raw_answers")
  assessmentQuestions AssessmentQuestion[]
  assessmentResult    AssessmentResult?
  child               Child                @relation(fields: [childId], references: [id], onDelete: Cascade)
  subject             Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model AssessmentQuestion {
  id             String     @id @default(uuid())
  assessmentId   String     @map("assessment_id")
  question       String
  expectedAnswer String     @map("expected_answer")
  aiExplanation  String?    @map("ai_explanation")
  metadata       Json?      @default("{}")
  createdAt      DateTime   @default(now()) @map("created_at")
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_questions")
}

model AssessmentResult {
  id              String     @id @default(uuid())
  assessmentId    String     @unique @map("assessment_id")
  rawScore        Int        @map("raw_score")
  normalizedScore Int        @map("normalized_score")
  strengths       Json?      @default("[]")
  weaknesses      Json?      @default("[]")
  aiSummary       String?    @map("ai_summary")
  evaluatedAt     DateTime   @default(now()) @map("evaluated_at")
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("assessment_results")
}

model LearningMemory {
